script = ExtResource("1_qf36u")
name = "Halmazok szimmetrikus differenciája (5.17)"
input = "a1: T halmaz, n1: egész, a2: T halmaz, n2: egész"
output = "b: T halmaz, db: egész"
lines = Array[String](["függvény HalmazSzimmetrikusDifferencia(a1: T halmaz, n1: egész, a2: T halmaz, n2: egész)", "\tb <- Létrehoz(T)[n1 + n2]", "\ti <- 1", "\tj <- 1", "\tdb <- 0", "\tciklus amíg (i <= n1) és (j <= n2)", "\t\tha a1[i] < a2[j] akkor", "\t\t\tdb <- db + 1", "\t\t\tb[db] <- a1[i]", "\t\t\ti <- i + 1", "\t\tkülönben ha a1[i] > a2[j] akkor", "\t\t\t\tdb <- db + 1", "\t\t\t\tb[db] <- a2[j]", "\t\t\t\tj <- j + 1", "\t\tkülönben", "\t\t\ti <- i + 1", "\t\t\tj <- j + 1", "\t\telágazás vége", "\tciklus vége", "\tciklus amíg i <= n1", "\t\tdb <- db + 1", "\t\tb[db] <- a1[i]", "\t\ti <- i + 1", "\tciklus vége", "\tciklus amíg j <= n2", "\t\tdb <- db + 1", "\t\tb[db] <- a2[j]", "\t\tj <- j + 1", "\tciklus vége", "\tvissza (b, db)", "függvény vége"])
metadata/_custom_type_script = "uid://bilbv0dlql50b"