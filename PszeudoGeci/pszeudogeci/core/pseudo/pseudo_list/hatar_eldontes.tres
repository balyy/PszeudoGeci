[resource]
script = ExtResource("1_qf36u")
name = "Módosított eldöntés rendezett tömbben (Alsó/Felső határ - 5.5)"
input = "x: T rendezett tömb, n: egész, alsóhatár: T, felsőhatár: T"
output = "van: logikai"
lines = Array[String](["függvény MódosítottEldöntésRendezettben(x: T rendezett tömb, n: egész, alsóhatár: T, felsőhatár: T)", "\tbal <- 1", "\tjobb <- n", "\tcenter <- [(bal+jobb)/2]", "\tciklus amíg (bal <= jobb) és nem ((alsóhatár <= x[center]) és (x[center] <= felsőhatár))", "\t\tha x[center] > felsőhatár akkor", "\t\t\tjobb <- center - 1", "\t\tkülönben", "\t\t\tbal <- center + 1", "\t\telágazás vége", "\t\tcenter <- [(bal+jobb)/2]", "\tciklus vége", "\tvan <- (bal <= jobb)", "\tvissza van", "függvény vége"])
metadata/_custom_type_script = "uid://bilbv0dlql50b"