lines = Array[String](["függvény FelezőMaximumkiválasztás(x: T tömb, bal: egész, jobb: egész)", "\tha bal = jobb akkor", "\t\tvissza bal", "\tkülönben", "\t\tcenter <- [(bal+jobb)/2]", "\t\tbalmax <- FelezőMaximumkiválasztás(x, bal, center)", "\t\tjobbmax <- FelezőMaximumkiválasztás(x, center + 1, jobb)", "\t\tha x[balmax] >= x[jobbmax] akkor", "\t\t\tvissza balmax", "\t\tkülönben", "\t\t\tvissza jobbmax", "\t\telágazás vége", "\telágazás vége", "függvény vége"])
