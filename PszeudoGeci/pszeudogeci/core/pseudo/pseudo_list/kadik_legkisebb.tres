[resource]
script = ExtResource("1_qf36u")
name = "k-adik legkisebb elem kiválasztása (6.6)"
input = "x: T tömb, bal: egész, jobb: egész, k: egész"
output = "k-adik legkisebb tömbelem értéke"
lines = Array[String](["függvény k-adikLegkisebbElem(x: T tömb, bal: egész, jobb: egész, k: egész)", "\tha bal = jobb akkor", "\t\tvissza x[bal]", "\tkülönben", "\t\tidx <- Szétválogat(x, bal, jobb)", "\t\tha k = idx - bal + 1 akkor", "\t\t\tvissza x[idx]", "\t\tkülönben ha k < idx - bal + 1 akkor", "\t\t\tvissza k-adikLegkisebbElem(x, bal, idx - 1, k)", "\t\tkülönben", "\t\t\tvissza k-adikLegkisebbElem(x, idx + 1, jobb, k - (idx - bal + 1))", "\t\telágazás vége", "\telágazás vége", "függvény vége"])
metadata/_custom_type_script = "uid://bilbv0dlql50b"