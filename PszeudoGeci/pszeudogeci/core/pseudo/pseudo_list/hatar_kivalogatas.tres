[resource]
script = ExtResource("1_qf36u")
name = "Módosított kiválogatás rendezett tömbben (Alsó/Felső határ - 5.8)"
input = "x: T rendezett tömb, n: egész, alsóhatár: T, felsőhatár: T"
output = "van: logikai, bal: egész, jobb: egész"
lines = Array[String](["függvény MódosítottKiválogatásRendezettben(x: T rendezett tömb, n: egész, alsóhatár: T, felsőhatár: T)", "\tbal <- 1", "\tjobb <- n", "\tcenter <- [(bal+jobb)/2]", "\tciklus amíg (bal <= jobb) és nem ((alsóhatár <= x[center]) és (x[center] <= felsőhatár))", "\t\tha x[center] > felsőhatár akkor", "\t\t\tjobb <- center - 1", "\t\tkülönben", "\t\t\tbal <- center + 1", "\t\telágazás vége", "\t\tcenter <- [(bal+jobb)/2]", "\tciklus vége", "\tvan <- (bal <= jobb)", "\tha van akkor", "\t\tbal <- center", "\t\tciklus amíg (bal > 1) és (x[bal - 1] >= alsóhatár)", "\t\t\tbal <- bal - 1", "\t\tciklus vége", "\t\tjobb <- center", "\t\tciklus amíg (jobb < n) és (x[jobb + 1] <= felsőhatár)", "\t\t\tjobb <- jobb + 1", "\t\tciklus vége", "\t\tvissza (van, bal, jobb)", "\tkülönben", "\t\tvissza van", "\telágazás vége", "függvény vége"])
metadata/_custom_type_script = "uid://bilbv0dlql50b"